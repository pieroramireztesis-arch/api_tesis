# ──────────────────────────────────────────────────────────────────
#  .env.example  —  Variables de entorno para la API (TutorMath)
#  Copia este archivo como .env para desarrollo local.
#  En Railway, configura estas variables en el panel "Variables".
# ──────────────────────────────────────────────────────────────────

# ── Base de datos ──────────────────────────────────────────────────
# Railway lo inyecta automáticamente al agregar el plugin PostgreSQL.
# En local, ponlo si usas una URL completa. Si no, deja comentado
# y usa los parámetros separados de abajo.
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/base_de_datos

# Parámetros separados (solo si NO usas DATABASE_URL)
PGHOST=127.0.0.1
PGPORT=5432
PGUSER=postgres
PGPASSWORD=hola1
PGDATABASE=bd_ejemplo

# ── Seguridad JWT ──────────────────────────────────────────────────
# ⚠️  Cambia esto por una cadena larga y aleatoria en producción.
JWT_SECRET_KEY=claveSuperSecreta2025

# ── Rutas de archivos estáticos ────────────────────────────────────
# En Railway no es necesario configurar esto:
# la ruta por defecto apunta a API_COMERCIAL/static/ejercicios_ayuda/
# EJERCICIOS_AYUDA_PATH=/ruta/a/ejercicios_ayuda

# ── URL interna de la API (usada por algunos endpoints) ───────────
# En Railway ponla con el dominio público generado.
# URL_APP=https://tu-api.up.railway.app/

# ── Cloudinary — almacenamiento permanente de imágenes ────────────
# Obtén estos valores en: https://console.cloudinary.com → Dashboard
# Usa el formato completo CLOUDINARY_URL (recomendado).
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME